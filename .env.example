# Copy to .env and fill in before running.

APP_ENV=development
PORT=3000
LOG_LEVEL=debug

# JWT signing secret.
# In production use RS256 — generate a keypair and put only the PUBLIC key here.
JWT_SECRET=ehecs-dev-secret-replace-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# DB_DRIVER selects the backend. Supported values:
#
#   memory     — in-memory, no persistence (default — dev and testing)
#   postgres   — PostgreSQL (recommended for cloud / Linux deployments)
#   sqlserver  — Microsoft SQL Server (in-house default for CSO infrastructure)
#
DB_DRIVER=memory

# DATABASE_URL — required for postgres and sqlserver, ignored for memory.
#
# PostgreSQL:
#   DATABASE_URL=postgres://ehecs:password@localhost:5432/ehecs?sslmode=require
#
# SQL Server (Windows Auth):
#   DATABASE_URL=sqlserver://localhost:1433?database=ehecs&encrypt=true&TrustServerCertificate=false
#
# SQL Server (SQL Auth):
#   DATABASE_URL=sqlserver://ehecs_user:password@localhost:1433?database=ehecs&encrypt=true
#
# DATABASE_URL=
